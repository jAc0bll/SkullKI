# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.installed.cfg

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
/env/
.env

# ── Trained model files (large — use Git LFS or transfer manually) ─────────────
models/skull_king/*.pt
models/skull_king/*.zip
bewertung/*.pt
# To share a model: git lfs track "*.pt"  or  scp models/skull_king/final_strat.pt user@server:path/

# ── Training logs (TensorBoard event files, regenerated by training) ───────────
logs/skull_king/*/

# ── Test / coverage ───────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ── Editors & OS ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ── Claude Code local config (machine-specific) ───────────────────────────────
.claude/

# ── Personal scratch files ────────────────────────────────────────────────────
Promts.txt
*.local.yaml
